{
  "name": "cng-banuba-sdk-workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ]
  },
  "scripts": {
    "sdk:build": "yarn workspace cng-editor-sdk build",
    "sdk:lint": "yarn workspace cng-editor-sdk lint",
    "sdk:test": "yarn workspace cng-editor-sdk test",
    "android": "yarn workspace cng-editor-example android",
    "ios": "yarn workspace cng-editor-example ios",
    "start": "yarn workspace cng-editor-example start",
    "example:android": "yarn workspace cng-editor-example android",
    "example:ios": "yarn workspace cng-editor-example ios",
    "example:start": "yarn workspace cng-editor-example start",
    "clean": "watchman watch-del-all 2>/dev/null; rm -rf $TMPDIR/metro-* $TMPDIR/haste-map-*",
    "start:reset": "yarn workspace cng-editor-example start --reset-cache"
  },
  "resolutions": {
    "react-native": "0.73.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
